{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3BinaryCacheReadWrite",
      "Effect": "Allow",
      "Action": [
        "s3:AbortMultipartUpload",
        "s3:GetBucketLocation",
        "s3:GetObject",
        "s3:ListBucket",
        "s3:ListBucketMultipartUploads",
        "s3:ListMultipartUploadParts",
        "s3:PutObject"
      ],
      "Resource": [
        "arn:aws:s3:::<NIX_CACHE_BUCKET_NAME>",
        "arn:aws:s3:::<NIX_CACHE_BUCKET_NAME>/*"
      ]
    },
    {
      "Sid": "CloudWatchLogsForRemoteBuildOutput",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogStream",
        "logs:DescribeLogGroups",
        "logs:DescribeLogStreams",
        "logs:PutLogEvents"
      ],
      "Resource": [
        "arn:aws:logs:<REGION>:<ACCOUNT_ID>:log-group:/github/remote-build/*",
        "arn:aws:logs:<REGION>:<ACCOUNT_ID>:log-group:/github/remote-build/*:log-stream:*"
      ]
    }
  ]
}
